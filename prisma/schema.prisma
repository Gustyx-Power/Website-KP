generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STAFF
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  role      Role      @default(STAFF)
  createdAt DateTime  @default(now())
  sessions  Session[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Toko {
  id        Int         @id @default(autoincrement())
  nama_toko String
  alamat    String?
  penjualan Penjualan[]
  retur     Retur[]
  stok      Stok[]
}

model Kategori {
  id            Int         @id @default(autoincrement())
  nama_kategori String
  penjualan     Penjualan[]
  retur         Retur[]
  stok          Stok[]
}

model Stok {
  id          Int      @id @default(autoincrement())
  jumlah      Int
  harga_modal Int
  id_toko     Int
  id_kategori Int
  kategori    Kategori @relation(fields: [id_kategori], references: [id], onDelete: Cascade)
  toko        Toko     @relation(fields: [id_toko], references: [id], onDelete: Cascade)
}

model Penjualan {
  id          Int      @id @default(autoincrement())
  tanggal     DateTime @default(now())
  qty_terjual Int
  total_uang  Int
  id_toko     Int
  id_kategori Int
  kategori    Kategori @relation(fields: [id_kategori], references: [id], onDelete: Cascade)
  toko        Toko     @relation(fields: [id_toko], references: [id], onDelete: Cascade)
}

model Retur {
  id          Int      @id @default(autoincrement())
  tanggal     DateTime @default(now())
  qty_retur   Int
  keterangan  String?
  id_toko     Int
  id_kategori Int
  kategori    Kategori @relation(fields: [id_kategori], references: [id], onDelete: Cascade)
  toko        Toko     @relation(fields: [id_toko], references: [id], onDelete: Cascade)
}
